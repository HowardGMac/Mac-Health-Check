    {
      "displayName": "Remediation Guide",
      "guidanceTitle": "How to Fix Issues",
      "icon": "https://usw2.ics.services.jamfcloud.com/icon/hash_08f287b1d7a9da36b733c0784031a4943bef3b82a2981eb937ab2f5b2bd55e91",
      "id": "remediation",
      "stepType": "info",
      "guidanceContent": [
        {
          "content": "**4 issues require your attention.** Follow the steps below to resolve them.",
          "type": "warning"
        },
        {
          "content": "macOS Version",
          "comparisonStyle": "columns",
          "expectedLabel": "Problem",
          "expected": "macOS 26.5 is no longer supported",
          "expectedColor": "#EB4C46",
          "expectedIcon": "xmark.circle.fill",
          "actualLabel": "What to do",
          "actual": "Update to a supported macOS version immediately for security patches.",
          "actualColor": "#F5BE0A",
          "actualIcon": "arrow.down.circle",
          "type": "comparison-table"
        },
        {
          "content": "AirDrop",
          "comparisonStyle": "columns",
          "expectedLabel": "Problem",
          "expected": "Currently set to 'Everyone'",
          "expectedColor": "#EB4C46",
          "expectedIcon": "xmark.circle.fill",
          "actualLabel": "What to do",
          "actual": "Change to 'No One' or 'Contacts Only' to prevent unauthorized sharing.",
          "actualColor": "#F5BE0A",
          "actualIcon": "airdrop",
          "type": "comparison-table"
        },
        {
          "content": "Downloads Folder",
          "comparisonStyle": "columns",
          "expectedLabel": "Problem",
          "expected": "140 GB used (15.13% of disk)",
          "expectedColor": "#F5BE0A",
          "expectedIcon": "exclamationmark.triangle.fill",
          "actualLabel": "What to do",
          "actual": "Delete large/unnecessary files or move them to OneDrive/iCloud.",
          "actualColor": "#34C759",
          "actualIcon": "folder.fill.badge.plus",
          "type": "comparison-table"
        },
        {
          "content": "App Auto-Patch",
          "comparisonStyle": "columns",
          "expectedLabel": "Problem",
          "expected": "Last run 17 days ago",
          "expectedColor": "#F5BE0A",
          "expectedIcon": "exclamationmark.triangle.fill",
          "actualLabel": "What to do",
          "actual": "Run App Auto-Patch from the Workforce App Store to update apps.",
          "actualColor": "#34C759",
          "actualIcon": "arrow.triangle.2.circlepath",
          "type": "comparison-table"
        }
      ]
    },
